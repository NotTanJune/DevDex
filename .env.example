# DevDex supports multiple providers. Set ONE of the following:

# Option 1: NVIDIA NIM 
NVIDIA_API_KEY=nvapi-...

# Option 2: Mistral AI
# MISTRAL_API_KEY=...

# Option 3: OpenAI
# OPENAI_API_KEY=sk-...

# Option 4: Any OpenAI-compatible provider
# DEVDEX_API_KEY=your-key
# DEVDEX_BASE_URL=https://your-provider.com/v1
# DEVDEX_PROVIDER=custom
